# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o

# Google Drive OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://myaircraft.us/api/gdrive/callback

# Google Document AI (primary scanned PDF OCR)
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=your-document-ai-processor-id
GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# AWS Textract (scanned PDF OCR fallback)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Trigger.dev
TRIGGER_API_KEY=tr_...
TRIGGER_API_URL=https://api.trigger.dev

# Parser Service (FastAPI)
PARSER_SERVICE_URL=https://parser.myaircraft.us
PARSER_SERVICE_SECRET=your-internal-secret

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Gmail SMTP (for invoice/notification emails)
GMAIL_USER=billing@myaircraft.us
GMAIL_APP_PASSWORD=your-gmail-app-password

# Vercel Cron Secret (protects cron endpoints from unauthorized calls)
CRON_SECRET=your-cron-secret

# eBay Parts Search
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_ENV=production

# SerpAPI (Google Shopping parts search)
SERPAPI_KEY=your-serpapi-key

# Stripe Connect (for per-mechanic payments)
STRIPE_CONNECT_CLIENT_ID=ca_...

# Encryption
ENCRYPTION_SECRET=your-32-char-encryption-key

# App
NEXT_PUBLIC_APP_URL=https://myaircraft.us

# Accounting integrations (OAuth)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://myaircraft.us/api/integrations/oauth/callback
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
FRESHBOOKS_REDIRECT_URI=https://myaircraft.us/api/integrations/oauth/callback
APP_SECRET=your-app-secret

# Sentry
SENTRY_DSN=...
NEXT_PUBLIC_SENTRY_DSN=...

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# FARAIM AI search (embed integration — server-side only, never expose to browser)
FARAIM_API_BASE=https://www.faraim.us
FARAIM_API_KEY=faraim_live_...
FARAIM_SANDBOX_KEY=faraim_sbx_...
FARAIM_PARTNER_ID=...
# Set FARAIM_ENV=sandbox to force sandbox key in production builds (default: live in prod, sandbox in dev)
FARAIM_ENV=
