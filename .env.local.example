# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o

# Google Drive OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=https://myaircraft.us/api/gdrive/callback

# Google Document AI (primary scanned PDF OCR)
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_ID=your-document-ai-processor-id
GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# AWS Textract (scanned PDF OCR fallback)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# Trigger.dev
TRIGGER_API_KEY=tr_...
TRIGGER_API_URL=https://api.trigger.dev

# Parser Service (FastAPI)
PARSER_SERVICE_URL=https://parser.myaircraft.us
PARSER_SERVICE_SECRET=your-internal-secret

# Stripe
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# Gmail SMTP (for invoice/notification emails)
GMAIL_USER=billing@myaircraft.us
GMAIL_APP_PASSWORD=your-gmail-app-password

# Vercel Cron Secret (protects cron endpoints from unauthorized calls)
CRON_SECRET=your-cron-secret

# eBay Parts Search
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id
EBAY_ENV=production

# SerpAPI (Google Shopping parts search)
SERPAPI_KEY=your-serpapi-key

# Stripe Connect (for per-mechanic payments)
STRIPE_CONNECT_CLIENT_ID=ca_...

# Encryption
ENCRYPTION_SECRET=your-32-char-encryption-key

# App
NEXT_PUBLIC_APP_URL=https://myaircraft.us

# Accounting integrations (OAuth)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=https://myaircraft.us/api/integrations/oauth/callback
FRESHBOOKS_CLIENT_ID=
FRESHBOOKS_CLIENT_SECRET=
FRESHBOOKS_REDIRECT_URI=https://myaircraft.us/api/integrations/oauth/callback
APP_SECRET=your-app-secret

# Sentry
SENTRY_DSN=...
NEXT_PUBLIC_SENTRY_DSN=...

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# FARAIM AI search (embed integration — server-side only, never expose to browser)
FARAIM_API_BASE=https://www.faraim.us
FARAIM_API_KEY=faraim_live_...
FARAIM_SANDBOX_KEY=faraim_sbx_...
FARAIM_PARTNER_ID=...
# Set FARAIM_ENV=sandbox to force sandbox key in production builds (default: live in prod, sandbox in dev)
FARAIM_ENV=

# Twilio (SMS for mechanic invites)
# Get these from https://console.twilio.com — buy a number first.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ElevenLabs (text-to-speech, server-side only)
# Get key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional: pin a default voice. Find IDs at https://elevenlabs.io/app/voice-library
ELEVENLABS_DEFAULT_VOICE_ID=

# ADSB Exchange via RapidAPI (Spec 4.3 — telemetry fallback, server-side only)
# Subscription required. Get the key at:
#   https://rapidapi.com/adsbx/api/adsbexchange-com1
# NEVER expose to the browser. Used by /api/integrations/adsb/sync only.
RAPIDAPI_ADSB_EXCHANGE_KEY=

# Anthropic Claude (Spec 5.6 — first production LLM use, server-side only)
# Used by the customer-approval explainer + ask handler. Never exposed to
# the browser. lib/ai/anthropic.ts throws if the var is missing rather
# than silently no-op'ing — same pattern as RAPIDAPI_ADSB_EXCHANGE_KEY.
ANTHROPIC_API_KEY=

# SendGrid Inbound Parse (Spec 7.2 — email-to-cost forwarding)
# Each org gets a forwarding address <orgId>@bills.aircraft.us. SendGrid
# POSTs the parsed email + attachments to /api/costs/email-webhook?key=$KEY.
# This is THE only public-internet entry; key is the auth.
# DNS MX setup: bills.aircraft.us → mx.sendgrid.net (priority 10).
SENDGRID_INBOUND_KEY=

# ─── Stub-layer env vars (Spec stub-layer-batch) ───────────────────────────
# Each stub-layer integration auto-detects mock vs real from env. Setting
# the credential vars below disables mock and routes to the real SDK/API.
# Set *_USE_MOCK=true to force mock even when credentials are present.

# Stripe billing (Spec 6.3) — STRIPE_SECRET_KEY auto-disables mock.
STRIPE_USE_MOCK=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# QuickBooks Online (Spec 3.3 + 5.7) — both ID + secret needed; QBO_ENV
# is 'sandbox' (default) or 'production'. QBO_WEBHOOK_VERIFIER is the
# Intuit-signature HMAC-SHA256 verifier token from the dev portal.
QBO_USE_MOCK=
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENV=sandbox
QBO_WEBHOOK_VERIFIER=

# Airbly telemetry (Spec 4.1) — AIRBLY_API_KEY auto-disables mock.
AIRBLY_USE_MOCK=
AIRBLY_API_KEY=
AIRBLY_API_BASE=

# FlightSchedule Pro telemetry (Spec 4.2) — both client id + secret needed.
FSP_USE_MOCK=
FSP_OAUTH_CLIENT_ID=
FSP_OAUTH_CLIENT_SECRET=
FSP_API_BASE=
FSP_OAUTH_BASE=

# ─── RAG accuracy: reranker (Wave 1) ───────────────────────────────────────
# Cohere Rerank — a cross-encoder rerank pass after the hybrid retrieval
# merge (the single biggest answer-accuracy lever). Server-side only.
# OPTIONAL + graceful: when COHERE_API_KEY is absent, retrieval runs exactly
# as before — no behavior change. Set the key in Vercel env to activate.
# Key: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# ─── Vision RAG — ColQwen2 visual-document retrieval ───────────────────────
# The vision pipeline embeds page IMAGES (diagrams, arrows, handwriting) via
# a Modal-hosted ColQwen2 endpoint. VISION_GPU_HOST routes the dispatcher;
# 'stub' synthesizes deterministic vectors (dev only).
VISION_GPU_HOST=stub             # stub | modal | colab | replicate | runpod
VISION_DISPATCH_MODE=            # direct | queue
VISION_AUTO_DISPATCH=
# Modal RUNTIME worker — the deployed ColQwen2 web endpoint the app calls.
# NOTE: this is NOT the `modal token set` CLI credential — it is the
# deployed app's web-endpoint URL + its bearer token.
MODAL_ENDPOINT_URL=https://your-colqwen2-app.modal.run
MODAL_API_KEY=
MODAL_TIMEOUT_MS=120000
# Modal CLI account credentials — only for `modal deploy` from a dev machine,
# not used by the running app.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# HuggingFace token — used by the GPU notebook/worker to pull ColQwen2 weights.
HUGGINGFACE_API_KEY=
