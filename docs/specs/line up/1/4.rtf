### 12.2 Row-Level Security (RLS) Policies\
\
```sql\
-- Enable RLS on all sensitive tables\
ALTER TABLE aircraft ENABLE ROW LEVEL SECURITY;\
ALTER TABLE logbook_entries ENABLE ROW LEVEL SECURITY;\
ALTER TABLE aircraft_access ENABLE ROW LEVEL SECURITY;\
\
-- Aircraft: user can see if they're in owning org OR have access record\
CREATE POLICY aircraft_tenant_isolation ON aircraft\
  USING (\
    owner_org_id = current_setting('app.tenant_id')::UUID\
    OR\
    id IN (\
      SELECT aircraft_id FROM aircraft_access\
      WHERE grantee_user_id = current_setting('app.user_id')::UUID\
        AND status = 'active'\
        AND (expires_at IS NULL OR expires_at > now())\
    )\
  );\
\
-- Logbook entries: user can see if they have book permission for that aircraft\
CREATE POLICY entries_access ON logbook_entries\
  USING (\
    org_id = current_setting('app.tenant_id')::UUID\
    OR\
    aircraft_id IN (\
      SELECT aircraft_id FROM aircraft_access\
      WHERE grantee_user_id = current_setting('app.user_id')::UUID\
        AND status = 'active'\
    )\
  );\
```\
