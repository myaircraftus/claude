  primary_owner_id  UUID NOT NULL REFERENCES users(id),\
  make              TEXT NOT NULL,\
  model             TEXT NOT NULL,\
  year              INT,\
  serial_number     TEXT,\
  category          TEXT,  -- 'normal','utility','acrobatic'\
  airworthiness     TEXT,  -- 'standard','special'\
