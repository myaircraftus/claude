\f0\b\fs34 \cf2 Migration 012 \'97 Community Library + Pricing\
\
CREATE TYPE library_scope AS ENUM ('private', 'shared', 'community');\
CREATE TYPE listing_status AS ENUM ('draft','pending_review','published','rejected','taken_down');\
CREATE TYPE pricing_mode AS ENUM ('free','paid');\
\
-- Community listings (only for maintenance_manual and parts_catalog)\
CREATE TABLE community_listings (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  uploader_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  organization_id UUID REFERENCES organizations(id) ON DELETE SET NULL, -- uploader's org (optional)\
  title TEXT NOT NULL,\
  doc_type doc_type NOT NULL,\
  make TEXT,\
  model TEXT,\
  revision TEXT,\
  description TEXT,\
  pricing_mode pricing_mode NOT NULL DEFAULT 'free',\
  price_cents INT NOT NULL DEFAULT 0,\
  currency TEXT NOT NULL DEFAULT 'USD',\
  revenue_split_platform_bps INT NOT NULL DEFAULT 5000, -- 50%\
  revenue_split_uploader_bps INT NOT NULL DEFAULT 5000, -- 50%\
  listing_status listing_status NOT NULL DEFAULT 'draft',\
  publish_at TIMESTAMPTZ,\
  taken_down_at TIMESTAMPTZ,\
  takedown_reason TEXT,\
  file_path TEXT NOT NULL, -- storage path for the listing file\
  checksum_sha256 TEXT,\
  page_count INT,\
  is_text_native BOOLEAN,\
  ocr_required BOOLEAN NOT NULL DEFAULT FALSE,\
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\
  CONSTRAINT community_doc_type CHECK (doc_type IN ('maintenance_manual','parts_catalog'))\
);\
\
CREATE INDEX idx_community_listings_status ON community_listings(listing_status);\
CREATE INDEX idx_community_listings_make_model ON community_listings(make, model);\
CREATE INDEX idx_community_listings_doc_type ON community_listings(doc_type);\
\
-- Uploader attestation\
CREATE TABLE community_uploader_attestations (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  listing_id UUID NOT NULL REFERENCES community_listings(id) ON DELETE CASCADE,\
  uploader_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  attestation_version TEXT NOT NULL,\
  agreed_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\
  ip_address INET,\
  user_agent TEXT\
);\
\
\
Migration 013 \'97 Purchases + Entitlements + Payout Accounting\
\
CREATE TYPE purchase_status AS ENUM ('pending','paid','refunded','failed');\
CREATE TYPE entitlement_type AS ENUM ('download','ingest');\
\
CREATE TABLE marketplace_purchases (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  listing_id UUID NOT NULL REFERENCES community_listings(id) ON DELETE CASCADE,\
  buyer_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  buyer_organization_id UUID REFERENCES organizations(id) ON DELETE SET NULL,\
  status purchase_status NOT NULL DEFAULT 'pending',\
  amount_cents INT NOT NULL,\
  currency TEXT NOT NULL DEFAULT 'USD',\
  stripe_checkout_session_id TEXT,\
  stripe_payment_intent_id TEXT,\
  paid_at TIMESTAMPTZ,\
  refunded_at TIMESTAMPTZ,\
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\
);\
\
CREATE INDEX idx_marketplace_purchases_buyer ON marketplace_purchases(buyer_user_id);\
CREATE INDEX idx_marketplace_purchases_listing ON marketplace_purchases(listing_id);\
\
-- Entitlement grants access to download/ingest\
CREATE TABLE marketplace_entitlements (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  purchase_id UUID NOT NULL REFERENCES marketplace_purchases(id) ON DELETE CASCADE,\
  buyer_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  listing_id UUID NOT NULL REFERENCES community_listings(id) ON DELETE CASCADE,\
  entitlement entitlement_type NOT NULL DEFAULT 'download',\
  expires_at TIMESTAMPTZ, -- optional (e.g., 7 days for download link)\
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\
  UNIQUE(purchase_id, entitlement)\
);\
\
-- Stripe Connect account for uploader payouts\
CREATE TABLE payout_accounts (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  uploader_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  stripe_connect_account_id TEXT NOT NULL,\
  onboarding_status TEXT NOT NULL DEFAULT 'pending',\
  payouts_enabled BOOLEAN NOT NULL DEFAULT FALSE,\
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\
  UNIQUE(uploader_user_id)\
);\
\
-- Ledger for revenue splits\
CREATE TABLE marketplace_ledger (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  purchase_id UUID NOT NULL REFERENCES marketplace_purchases(id) ON DELETE CASCADE,\
  listing_id UUID NOT NULL REFERENCES community_listings(id) ON DELETE CASCADE,\
  uploader_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  gross_amount_cents INT NOT NULL,\
  platform_amount_cents INT NOT NULL,\
  uploader_amount_cents INT NOT NULL,\
  currency TEXT NOT NULL DEFAULT 'USD',\
  stripe_fee_cents INT NOT NULL DEFAULT 0,\
  net_uploader_amount_cents INT NOT NULL,\
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\
);\
\
Migration 014 \'97 Reviews + Quality Signals + Reports\
\
CREATE TABLE community_reviews (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  listing_id UUID NOT NULL REFERENCES community_listings(id) ON DELETE CASCADE,\
  reviewer_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  rating INT NOT NULL CHECK (rating BETWEEN 1 AND 5),\
  review_text TEXT,\
  is_verified_purchase BOOLEAN NOT NULL DEFAULT FALSE,\
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),\
  UNIQUE(listing_id, reviewer_user_id)\
);\
\
CREATE TABLE community_reports (\
  id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),\
  listing_id UUID NOT NULL REFERENCES community_listings(id) ON DELETE CASCADE,\
  reporter_user_id UUID NOT NULL REFERENCES user_profiles(id) ON DELETE CASCADE,\
  reason TEXT NOT NULL, -- copyright/incomplete/wrong_aircraft/malware/etc.\
  details TEXT,\
  status TEXT NOT NULL DEFAULT 'open', -- open/in_review/closed\
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()\
);\
\
