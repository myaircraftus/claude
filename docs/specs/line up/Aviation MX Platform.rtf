\f0\b\fs36 \cf0 \strokec2 12. Database Schema\
\pard\pardeftab720\sa280\partightenfactor0

\fs28 \cf0 12.1 Core Tables\
\pard\pardeftab720\partightenfactor0

\f4\b0\fs26 \cf0 -- ORGANIZATIONS (tenants)\
CREATE TABLE organizations (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  name            TEXT NOT NULL,\
  org_type        TEXT NOT NULL,  -- 'flight_school','mro','individual','charter'\
  slug            TEXT UNIQUE NOT NULL,\
  country         TEXT,\
  state           TEXT,\
  plan            TEXT DEFAULT 'starter',\
  stripe_customer_id TEXT,\
  created_at      TIMESTAMPTZ DEFAULT now(),\
  is_active       BOOLEAN DEFAULT true\
);\
\
-- USERS\
CREATE TABLE users (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  email           TEXT UNIQUE NOT NULL,\
  email_verified  BOOLEAN DEFAULT false,\
  password_hash   TEXT,\
  google_id       TEXT UNIQUE,\
  microsoft_id    TEXT UNIQUE,\
  full_name       TEXT NOT NULL,\
  avatar_url      TEXT,\
  created_at      TIMESTAMPTZ DEFAULT now(),\
  last_login      TIMESTAMPTZ,\
  is_active       BOOLEAN DEFAULT true\
);\
\
-- ORG MEMBERSHIPS (links users to orgs with roles)\
CREATE TABLE org_memberships (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  org_id          UUID NOT NULL REFERENCES organizations(id),\
  user_id         UUID NOT NULL REFERENCES users(id),\
  role            TEXT NOT NULL,  -- 'owner','owner_admin','mechanic','amp','ojt','viewer'\
  is_primary_org  BOOLEAN DEFAULT false,  -- mechanic's "home" org\
  invited_by      UUID REFERENCES users(id),\
  joined_at       TIMESTAMPTZ DEFAULT now(),\
  UNIQUE(org_id, user_id)\
);\
\
-- MECHANIC PROFILES\
CREATE TABLE mechanic_profiles (\
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  user_id               UUID NOT NULL UNIQUE REFERENCES users(id),\
  legal_name            TEXT NOT NULL,  -- must match FAA certificate\
  faa_certificate_number TEXT,\
  certificate_type      TEXT,  -- 'ap','ia','repairman','foreign'\
  ratings               TEXT[],  -- ['airframe','powerplant']\
  ia_authorized         BOOLEAN DEFAULT false,\
  ia_expiry_date        DATE,\
  ia_reminder_sent      BOOLEAN DEFAULT false,\
  verified              BOOLEAN DEFAULT false,\
  verified_at           TIMESTAMPTZ,\
  created_at            TIMESTAMPTZ DEFAULT now()\
);\
\
-- MECHANIC CERTIFICATES (documents)\
CREATE TABLE mechanic_certificates (\
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  mechanic_id   UUID NOT NULL REFERENCES mechanic_profiles(id),\
  cert_type     TEXT NOT NULL,  -- 'faa_ap','ia_auth','repairman','training'\
  document_url  TEXT,\
  expiry_date   DATE,\
  uploaded_at   TIMESTAMPTZ DEFAULT now()\
);\
\
-- AIRCRAFT\
CREATE TABLE aircraft (\
  id                UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  aircraft_uid      TEXT UNIQUE NOT NULL,  -- 'AX-N1234X-2018'\
  n_number          TEXT NOT NULL,\
  owner_org_id      UUID NOT NULL REFERENCES organizations(id),\
  primary_owner_id  UUID NOT NULL REFERENCES users(id),\
  make              TEXT NOT NULL,\
  model             TEXT NOT NULL,\
  year              INT,\
  serial_number     TEXT,\
  category          TEXT,  -- 'normal','utility','acrobatic'\
  airworthiness     TEXT,  -- 'standard','special'\
  total_time_hrs    DECIMAL(8,1),\
  faa_registry_data JSONB,  -- raw FAA lookup result\
  created_at        TIMESTAMPTZ DEFAULT now(),\
  is_active         BOOLEAN DEFAULT true,\
  deleted_at        TIMESTAMPTZ  -- soft delete\
);\
\
-- AIRCRAFT ENGINES\
CREATE TABLE aircraft_engines (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  aircraft_id     UUID NOT NULL REFERENCES aircraft(id),\
  position        INT NOT NULL DEFAULT 1,  -- 1, 2 for twin\
  make            TEXT,\
  model           TEXT,\
  serial_number   TEXT,\
  total_time_hrs  DECIMAL(8,1),\
  time_since_oh   DECIMAL(8,1),\
  tbo_hrs         INT,\
  created_at      TIMESTAMPTZ DEFAULT now()\
);\
\
-- AIRCRAFT PROPELLERS\
CREATE TABLE aircraft_propellers (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  aircraft_id     UUID NOT NULL REFERENCES aircraft(id),\
  position        INT NOT NULL DEFAULT 1,\
  make            TEXT,\
  model           TEXT,\
  serial_number   TEXT,\
  total_time_hrs  DECIMAL(8,1),\
  time_since_oh   DECIMAL(8,1),\
  created_at      TIMESTAMPTZ DEFAULT now()\
);\
\
-- AIRCRAFT ACCESS (cross-user / cross-org sharing)\
CREATE TABLE aircraft_access (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  aircraft_id     UUID NOT NULL REFERENCES aircraft(id),\
  grantee_user_id UUID NOT NULL REFERENCES users(id),\
  granted_by_id   UUID NOT NULL REFERENCES users(id),\
  role            TEXT NOT NULL,  -- 'mechanic','amp','ojt','viewer'\
  book_permissions JSONB NOT NULL DEFAULT '\{\}',\
  -- Example: \{"airframe": "rw", "engine_1": "rw", "prop": "r", "engine_2": "none"\}\
  status          TEXT DEFAULT 'active',  -- 'active','revoked','expired'\
  expires_at      TIMESTAMPTZ,\
  granted_at      TIMESTAMPTZ DEFAULT now(),\
  revoked_at      TIMESTAMPTZ,\
  revoked_by_id   UUID REFERENCES users(id),\
  UNIQUE(aircraft_id, grantee_user_id)\
);\
\
-- INVITATIONS\
CREATE TABLE invitations (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  org_id          UUID REFERENCES organizations(id),\
  inviter_id      UUID NOT NULL REFERENCES users(id),\
  invitee_email   TEXT NOT NULL,\
  invitee_user_id UUID REFERENCES users(id),  -- set when accepted\
  role            TEXT NOT NULL,\
  token           TEXT UNIQUE NOT NULL,  -- 32-byte hex\
  aircraft_config JSONB,  -- pre-configured aircraft access\
  message         TEXT,\
  status          TEXT DEFAULT 'pending',  -- 'pending','accepted','declined','expired','revoked'\
  type            TEXT DEFAULT 'org_member',  -- 'org_member','aircraft_access','sub_user'\
  expires_at      TIMESTAMPTZ NOT NULL,\
  created_at      TIMESTAMPTZ DEFAULT now(),\
  responded_at    TIMESTAMPTZ\
);\
\
-- LOGBOOKS\
CREATE TABLE logbooks (\
  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  aircraft_id     UUID NOT NULL REFERENCES aircraft(id),\
  logbook_type    TEXT NOT NULL,  -- 'airframe','engine_1','engine_2','prop','component'\
  org_id          UUID NOT NULL REFERENCES organizations(id),\
  name            TEXT,\
  created_at      TIMESTAMPTZ DEFAULT now(),\
  is_active       BOOLEAN DEFAULT true\
);\
\
-- LOGBOOK ENTRIES\
CREATE TABLE logbook_entries (\
  id                    UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  logbook_id            UUID NOT NULL REFERENCES logbooks(id),\
  aircraft_id           UUID NOT NULL REFERENCES aircraft(id),\
  org_id                UUID NOT NULL REFERENCES organizations(id),\
  entry_date            DATE NOT NULL,\
  aircraft_total_time   DECIMAL(8,1),\
  work_performed        TEXT NOT NULL,\
  regulatory_basis      TEXT,\
  reference_documents   TEXT[],\
  parts_used            JSONB DEFAULT '[]',\
  status                TEXT DEFAULT 'draft',\
  -- 'draft','pending_review','signed','countersigned','archived'\
  created_by_id         UUID NOT NULL REFERENCES users(id),\
  signed_by_id          UUID REFERENCES users(id),\
  signed_at             TIMESTAMPTZ,\
  signer_certificate    TEXT,\
  signer_legal_name     TEXT,\
  signature_hash        TEXT,\
  ia_countersigned_by   UUID REFERENCES users(id),\
  ia_countersigned_at   TIMESTAMPTZ,\
  ia_certificate        TEXT,\
  amended_entry_id      UUID REFERENCES logbook_entries(id),\
  created_at            TIMESTAMPTZ DEFAULT now(),\
  updated_at            TIMESTAMPTZ DEFAULT now()\
);\
\
-- DOCUMENTS (library)\
CREATE TABLE documents (\
  id            UUID PRIMARY KEY DEFAULT gen_random_uuid(),\
  title         TEXT NOT NULL,\
  doc_type      TEXT NOT NULL,  -- 'manual','sb','ad','catalog','checklist','form'\
  scope         TEXT NOT NULL,  -- 'personal','org','community'\
  owner_user_id UUID REFERENCES users(id),\
  owner_org_id  UUID REFERENCES organizations(id),\
  file_url      TEXT,\
  file_size_bytes BIGINT,\
  manufacturer  TEXT,\
  model_applicability TEXT[],\
  revision      TEXT,\
  revision_date DATE,\
  tags          TEXT[],\
  is_active     BOOLEAN DEFAULT true,\
  downloads     INT DEFAULT 0,\
  rating        DECIMAL(3,2),\
  created_at    TIMESTAMPTZ DEFAULT now()\
);\
\
-- AIRCRAFT DOCUMENTS (links documents to aircraft)\
CREATE TABLE aircraft_documents (\
  aircraft_id   UUID NOT NULL REFERENCES aircraft(id),\
  document_id   UUID NOT NULL REFERENCES documents(id),\
  linked_by     UUID NOT NULL REFERENCES users(id),\
  linked_at     TIMESTAMPTZ DEFAULT now(),\
  PRIMARY KEY (aircraft_id, document_id)\
);\
\
-- AUDIT LOG\
CREATE TABLE audit_log (\
  id            BIGSERIAL PRIMARY KEY,\
  org_id        UUID REFERENCES organizations(id),\
  user_id       UUID REFERENCES users(id),\
  action        TEXT NOT NULL,\
  resource_type TEXT NOT NULL,  -- 'aircraft','logbook_entry','invitation','user'\
  resource_id   UUID,\
  old_value     JSONB,\
  new_value     JSONB,\
  ip_address    INET,\
  user_agent    TEXT,\
  created_at    TIMESTAMPTZ DEFAULT now()\
);\
\pard\pardeftab720\sa280\partightenfactor0

\f0\b\fs28 \cf0 12.2 Row-Level Security (RLS) Policies\
\pard\pardeftab720\partightenfactor0

\f4\b0\fs26 \cf0 -- Enable RLS on all sensitive tables\
ALTER TABLE aircraft ENABLE ROW LEVEL SECURITY;\
ALTER TABLE logbook_entries ENABLE ROW LEVEL SECURITY;\
ALTER TABLE aircraft_access ENABLE ROW LEVEL SECURITY;\
\
-- Aircraft: user can see if they're in owning org OR have access record\
CREATE POLICY aircraft_tenant_isolation ON aircraft\
  USING (\
    owner_org_id = current_setting('app.tenant_id')::UUID\
    OR\
    id IN (\
      SELECT aircraft_id FROM aircraft_access\
      WHERE grantee_user_id = current_setting('app.user_id')::UUID\
        AND status = 'active'\
        AND (expires_at IS NULL OR expires_at > now())\
    )\
  );\
\
-- Logbook entries: user can see if they have book permission for that aircraft\
CREATE POLICY entries_access ON logbook_entries\
  USING (\
    org_id = current_setting('app.tenant_id')::UUID\
    OR\
    aircraft_id IN (\
      SELECT aircraft_id FROM aircraft_access\
      WHERE grantee_user_id = current_setting('app.user_id')::UUID\
        AND status = 'active'\
    )\
  );\
\pard\pardeftab720\partightenfactor0

