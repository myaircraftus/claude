\fs28 \cf0 11.1 Three-Tier Library System\
\pard\pardeftab720\partightenfactor0

\f4\b0\fs26 \cf0 TIER 1: PERSONAL LIBRARY\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Documents you uploaded\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Only you can see them\
  
\f3 \uc0\u9492 \u9472 \u9472 
\f4  Can promote to Org Library\
\
TIER 2: ORGANIZATION LIBRARY\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Shared within your org/workspace\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  All org members with access can view\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Owner/Admin can manage\
  
\f3 \uc0\u9492 \u9472 \u9472 
\f4  Can publish to Community (optional)\
\
TIER 3: COMMUNITY LIBRARY\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Public documents shared by platform users\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Read-only for all users\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Curated/moderated by platform\
  
\f3 \uc0\u9500 \u9472 \u9472 
\f4  Includes: AMMs, SBs, ADs, parts catalogs\
  
\f3 \uc0\u9492 \u9472 \u9472 
\f4  Mechanics can "save to personal" any community doc\
