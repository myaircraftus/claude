{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "installCommand": "cd ../.. && corepack enable && pnpm install --frozen-lockfile=false",
  "buildCommand": "cd ../.. && pnpm --filter @myaircraft/web build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/heal-ingestions",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/integrations/adsb/sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/wo-audit",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/maintenance-predictions",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/trash-purge",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/airbly-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/fsp-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/telemetry-inference",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/extract-receipts-sweep",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/vision-dispatch-sweep",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/vision-fallback-sweep",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/documents/(.*)/preview",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
